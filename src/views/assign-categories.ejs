<%- include('partials/header') %>
<main>
    <h1><%= projectDetails.title %></h1>

    <form action="/assign-categories/<%= projectId %>" method="POST" class="form-card">
        <fieldset>
            <legend>Assign Categories</legend>
            <% categories.forEach(function(category) { %>
                <div class="checkbox-row">
                    <input
                        type="checkbox"
                        id="category-<%= category.category_id %>"
                        name="categoryIds"
                        value="<%= category.category_id %>"
                        <%= assignedCategories.some(assigned => assigned.category_id === category.category_id) ? 'checked' : '' %>
                    >
                    <label for="category-<%= category.category_id %>"><%= category.name %></label>
                </div>
            <% }) %>
        </fieldset>

        <button type="submit">Update Categories</button>
    </form>
</main>
<%- include('partials/footer') %>
