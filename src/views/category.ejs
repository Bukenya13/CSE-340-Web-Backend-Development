<%- include('partials/header') %>
<main>
    <h1><%= category.name %></h1>
    <p><a class="action-link" href="/edit-category/<%= category.category_id %>">Edit Category</a></p>
    <section>
        <h2>Service Projects</h2>
        <% if (projects.length > 0) { %>
            <ul class="project-list">
                <% projects.forEach(function(project) { %>
                    <li class="project-item">
                        <h3><a href="/project/<%= project.project_id %>"><%= project.title %></a></h3>
                        <p><strong>Date:</strong> <%= project.date ? new Date(project.date).toLocaleDateString() : 'TBD' %></p>
                        <p><strong>Organization:</strong> <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a></p>
                        <p><%= project.description %></p>
                        <p><em>Location: <%= project.location %></em></p>
                    </li>
                <% }) %>
            </ul>
        <% } else { %>
            <p>No service projects are currently listed for this category.</p>
        <% } %>
    </section>
</main>
<%- include('partials/footer') %>
