<%- include('partials/header') %>
    <main>
        <h1>
            <%= title %>
        </h1>
        <p>Here are a few of our partner organizations:</p>
        <ul class="organization-list">
            <% organizations.forEach(org=> { %>
                <li class="organization-item">
                    <img src="/images/<%= org.logo_filename %>" alt="<%= org.name %> logo" width="100">
                    <strong>
                        <%= org.name %>
                    </strong>: <%= org.contact_email %>
                    <p><%= org.description %></p>
                </li>
                <% }) %>
        </ul>
    </main>
<%- include('partials/footer') %>
