<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>
    <h2>Upcoming Service Projects</h2>
    <ul class="project-list">
        <% projects.forEach(function(project) { %>
            <li class="project-item">
                <strong><%= project.date ? new Date(project.date).toLocaleDateString() : 'TBD' %>:</strong> 
                <%= project.title %> (<%= project.organization_name %>)
                <p><strong>Category:</strong> <%= project.category_name %></p>
                <p><%= project.description %></p>
                <p><em>Location: <%= project.location %></em></p>
            </li>
        <% }) %>
    </ul>
</main>
<%- include('partials/footer') %>
